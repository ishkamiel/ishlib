# ishproject -- project-scoped wrapper around ishfiles entry point.
# Interpreter selection lives in _ishlib_launch.sh; see CLAUDE.md §Entry scripts.

set -eu

# Resolve $0 through symlinks so we can find the sibling launcher file.
_self="$0"
while [ -L "$_self" ]; do
    _link=$(readlink -- "$_self")
    case "$_link" in
        /*) _self="$_link" ;;
        *)  _self="$(dirname -- "$_self")/$_link" ;;
    esac
done
_bin_dir=$(cd -P "$(dirname -- "$_self")" && pwd)

# shellcheck source=./_ishlib_launch.sh
. "$_bin_dir/_ishlib_launch.sh"
ishlib_launch ishproject pyishlib.ishproject "$_bin_dir" "$@"
