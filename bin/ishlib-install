#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (C) 2026 Hans Liljestrand <hans@liljestrand.dev>
# Bootstrap: install ishlib tool launchers into ~/.local/bin/.
set -eu

_self="$0"
while [ -L "$_self" ]; do
    _link=$(readlink -- "$_self")
    case "$_link" in
        /*) _self="$_link" ;;
        *)  _self="$(dirname -- "$_self")/$_link" ;;
    esac
done
_bin_dir=$(cd -P "$(dirname -- "$_self")" && pwd)
_repo_src=$(cd -P "$_bin_dir/.." && pwd)/src

export PYTHONPATH="$_repo_src${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m pyishlib.launchers install --source "$_repo_src" "$@"
