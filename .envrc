# Require pyenv — abort early with a clear message if missing.
has pyenv || { log_error "pyenv is required but not found. See: https://github.com/pyenv/pyenv"; return 1; }

# Pin venv location to .venv/ for IDE auto-detection (VS Code, PyCharm).
export VIRTUAL_ENV="$PWD/.venv"

# Override layout_pyenv to fix Python 3.12+ incompatibility: pkgutil.find_loader
# was removed in 3.12, breaking direnv's bundled stdlib version.
layout_pyenv() {
  local python_version=$1
  local pyenv_python
  pyenv_python="$(pyenv root)/versions/${python_version}/bin/python"
  [[ -x "$pyenv_python" ]] || {
    log_error "pyenv: python ${python_version} not installed. Run: pyenv install ${python_version}"
    return 1
  }

  if [[ ! -d "$VIRTUAL_ENV" ]]; then
    log_status "Creating virtualenv at $VIRTUAL_ENV with python ${python_version}"
    "$pyenv_python" -m venv "$VIRTUAL_ENV"
  fi

  export VIRTUAL_ENV
  PATH_add "$VIRTUAL_ENV/bin"
  export PYENV_VERSION="$python_version"
}

# layout pyenv reads .python-version, creates the venv at $VIRTUAL_ENV,
# and prepends its bin/ to PATH.
# IMPORTANT: .python-version must contain an *exact* pyenv version (e.g. 3.13.2),
# not just a prefix (e.g. 3.13) — layout pyenv does not fuzzy-match like pyenv itself.
# To list installed versions: pyenv versions. To install: pyenv install 3.x.y
layout pyenv "$(< .python-version)"

# Auto-install requirements when the venv is fresh or requirements files change.
# To force a re-install: rm "$VIRTUAL_ENV/.requirements-installed" (or rm -rf .venv)
_req_hash=$(md5sum requirements.txt requirements-dev.txt 2>/dev/null | md5sum | cut -d' ' -f1)
if [[ "$(cat "$VIRTUAL_ENV/.requirements-installed" 2>/dev/null)" != "$_req_hash" ]]; then
    log_status "Installing Python requirements (requirements-dev.txt)..."
    pip install -q -r requirements-dev.txt \
        && echo "$_req_hash" > "$VIRTUAL_ENV/.requirements-installed"
fi
unset _req_hash
